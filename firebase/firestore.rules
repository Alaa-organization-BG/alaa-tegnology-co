rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isDealer() {
      // Check if user has dealer role in custom claims or profile
      return isSignedIn() && (
        request.auth.token.role == 'dealer' || 
        get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == 'dealer'
      );
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    // Vehicle Collections (Multi-collection pattern)
    // There are 12 vehicle collections, we apply the same security logic
    match /{vehicleCollection}/{vehicleId} {
      allow read: if resource.data.isActive == true; // Only show active listings to public
      allow write: if isDealer(); // Only verified dealers can list/edit
      
      // Allow dealers to only edit their own listings
      allow update, delete: if isDealer() && resource.data.dealerId == request.auth.uid;
    }

    // User Profiles
    match /users/{userId} {
      allow read: if true;
      allow write: if isOwner(userId);
    }

    // Messaging (v2)
    match /chats/{chatId} {
      allow read, write: if isSignedIn() && request.auth.uid in resource.data.participants;
    }
  }
}
