rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    // Helper: is the user authenticated
    function isSignedIn() {
      return request.auth != null;
    }

    // Helper: check image size and type
    function isValidImage() {
      return request.resource.size < 5 * 1024 * 1024 // 5MB limit
          && request.resource.contentType.matches('image/.*');
    }

    // Production images
    match /vehicles/{vehicleId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && isValidImage();
    }
    
    // Temp/Draft images for new listings
    match /temp/{userId}/{allPaths=**} {
      allow read, write: if isSignedIn() && request.auth.uid == userId && isValidImage();
    }
    
    // User profile images
    match /avatars/{userId}/{allPaths=**} {
      allow read: if true;
      allow write: if isSignedIn() && request.auth.uid == userId && isValidImage();
    }
  }
}
